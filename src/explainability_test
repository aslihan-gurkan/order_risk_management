"""
Model explainability modülü.


Amaç:
    Eğitilen en iyi modelin kararlarını yorumlamak.
    Eğitilen modelin hangi feature'lara göre risk tahmini yaptığını analiz etmek.

Yöntem:
    SHAP (SHapley Additive exPlanations)

Bu modülde:
    1. Best model yüklenir
    2. Preprocessor yüklenir
    3. Test verisi hazırlanır
    4. Feature importance çıkarılır
    5. SHAP analizi yapılır
    6. Sonuçlar data/outputs altına kaydedilir

    Model sadece tahmin üretmemelidir.
    Operasyon ekipleri riskin neden oluştuğunu da anlamalıdır.
"""

from pathlib import Path

import joblib
import pandas as pd
import shap
import numpy as np
import matplotlib.pyplot as plt
from src.config import (
    MODELS_PATH,
    OUTPUTS_PATH,
    PROCESSED_PATH,
)

from src.config import (
    MODELS_PATH,
    OUTPUTS_PATH,
)
from src.logger import get_logger

logger = get_logger(__name__)

EXPLAINABILITY_OUTPUT_PATH = Path(OUTPUTS_PATH) / "explainability"
EXPLAINABILITY_OUTPUT_PATH.mkdir(parents=True, exist_ok=True)

def generate_shap_analysis(
    model,
    X_sample: pd.DataFrame,
    max_display: int = 20,
):
    """
    SHAP analizi oluşturur.
    """

    logger.info("=" * 60)
    logger.info("ADIM 7 - SHAP analizi başladı")
    logger.info("=" * 60)

    logger.info(f"Sample shape: {X_sample.shape}")

    #explainer = shap.TreeExplainer(model)
    if hasattr(model, 'get_booster'):
        explainer = shap.TreeExplainer(model.get_booster())
    else:
        explainer = shap.TreeExplainer(model)

    shap_values = explainer.shap_values(X_sample)

    logger.info("SHAP values hesaplandı")

    plt.figure()

    shap.summary_plot(
        shap_values,
        X_sample,
        show=False,
        max_display=max_display
    )

    summary_path = (
        EXPLAINABILITY_OUTPUT_PATH /
        "shap_summary.png"
    )

    plt.savefig(summary_path, bbox_inches="tight")
    plt.close()

    logger.info(f"SHAP summary kaydedildi: {summary_path}")

    """importance_df = pd.DataFrame({
        "feature": X_sample.columns,
        "importance": abs(shap_values).mean(axis=0)
    })"""
    # Random Forest için shap_values list of arrays döndürür
    # Pozitif class (index 1) kullan
    if isinstance(shap_values, list):
        sv = shap_values[1]
    else:
        sv = shap_values

    importance_df = pd.DataFrame({
        "feature": X_sample.columns,
        "importance": abs(sv).mean(axis=0)
    })

    importance_df = importance_df.sort_values(
        "importance",
        ascending=False
    )

    importance_path = (
        EXPLAINABILITY_OUTPUT_PATH /
        "feature_importance.csv"
    )

    importance_df.to_csv(importance_path, index=False)

    logger.info(
        f"Feature importance kaydedildi: {importance_path}"
    )

    logger.info("=" * 60)
    logger.info("SHAP analizi tamamlandı")
    logger.info("=" * 60)

    return importance_df


if __name__ == "__main__":
