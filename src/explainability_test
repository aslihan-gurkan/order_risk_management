    # XGBoost yerine Random Forest yükle - SHAP uyumluluğu için
    import joblib
    from sklearn.ensemble import RandomForestClassifier
    
    # Tüm modelleri içeren benchmark sonuçlarından RF'i al
    # En kolay yol: modeli yeniden eğit
    X_train = np.load(
