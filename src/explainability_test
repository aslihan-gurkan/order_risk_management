    feature_names = pd.read_csv(
        Path(PROCESSED_PATH) / "model_input" / "feature_names.csv"
    )
    feature_names = feature_names.iloc[:, 0].tolist()
    
    # Random Forest eğit
    from src.config import RANDOM_STATE
    rf_model = RandomForestClassifier(
        n_estimators=300,
        max_depth=None,
        min_samples_leaf=5,
